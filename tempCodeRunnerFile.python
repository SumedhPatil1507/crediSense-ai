import pandas as pd
import numpy as np

print("┌──────────────────────────────────────────────┐")
print("             STEP 1: BASIC INFORMATION        ")
print("└──────────────────────────────────────────────┘\n")

df=pd.read_csv('/kaggle/input/loan-default-risk-dataset-with-feature-engineering/loan_cleaned.csv')

# Basic structure
print("Shape of dataset:", df.shape)
print("\nColumns in the dataset:")
print(df.columns.tolist())

print("\n" + "═" * 60)
print("                 df.info()")
print("═" * 60)
df.info()

# ─── 2. Missing values check ───────────────────────────────────────
print("\n" + "═" * 60)
print("          Missing Values Analysis")
print("═" * 60)
missing = df.isnull().sum()
missing_percent = (missing / len(df)) * 100
missing_df = pd.DataFrame({
    'Missing Count': missing,
    'Missing %': missing_percent.round(3)
}).sort_values('Missing Count', ascending=False)

print("Missing values per column:")
print(missing_df[missing_df['Missing Count'] > 0])

if missing.sum() == 0:
    print("\n🎉 Great! No missing values found in the dataset.")
else:
    print("\n⚠️  Missing values detected — decide on imputation strategy.")

# ─── 3. Quick statistical summary ──────────────────────────────────
print("\n" + "═" * 60)
print("          Numerical Features Summary (df.describe())")
print("═" * 60)
print(df.describe().round(4).T)

print("\n" + "═" * 60)
print("          Object/Categorical Features Summary")
print("═" * 60)
print(df.describe(include='object').T)

# ─── 4. Target variable distribution ───────────────────────────────
print("\n" + "═" * 60)
print("          Target Variable (Risk_Flag) Distribution")
print("═" * 60)
print(df['Risk_Flag'].value_counts(normalize=True).mul(100).round(2).astype(str) + ' %')
print("\nClass imbalance ratio (minority/majority):",
      round((df['Risk_Flag']==1).mean() / (df['Risk_Flag']==0).mean(), 4))

# ─── 5. Data Cleaning & Type corrections ───────────────────────────
print("\n" + "═" * 60)
print("          DATA CLEANING STEPS")
print("═" * 60)

# 5.1 Fix any suspicious float-looking integer columns
int_like_cols = ['CURRENT_JOB_YRS', 'CURRENT_HOUSE_YRS', 'stability_score']

for col in int_like_cols:
    if col in df.columns:
        df[col] = df[col].round(0).astype(int)
        print(f"→ Converted {col} → integer")

# 5.2 Fix Risk_Flag to proper integer (in case it's float)
if df['Risk_Flag'].dtype != 'int':
    df['Risk_Flag'] = df['Risk_Flag'].astype(int)
    print("→ Risk_Flag converted to integer")

# 5.3 Check & fix negative / impossible values (if any)
print("\nChecking for unrealistic values:")
print("Income < 0 :", (df['Income'] < 0).sum())
print("Age < 0     :", (df['Age'] < 0).sum())
print("Experience < 0 :", (df['Experience'] < 0).sum())

# Optional: cap extreme values (example - you may skip or adjust)
# df['income_per_experience'] = df['income_per_experience'].clip(upper=5_000_000)

# ─── 6. Feature Engineering Ideas (you can expand later) ────────────
print("\nPossible new features to consider:")
print("• income_per_job_year = Income / (CURRENT_JOB_YRS + 1)")
print("• total_stability   = CURRENT_JOB_YRS + CURRENT_HOUSE_YRS")
print("• young_professional = (age_group == 'Young') & (Experience <= 0.3)")
print("• high_income_old    = (age_group.isin(['Senior','Old'])) & (Income > 0.8)")

# ─── 7. Encoding plan preview ──────────────────────────────────────
print("\n" + "═" * 60)
print("          CATEGORICAL COLUMNS TO ENCODE")
print("═" * 60)
cat_cols = ['Married/Single', 'House_Ownership', 'Car_Ownership',
            'Profession', 'CITY', 'STATE', 'age_group']

for col in cat_cols:
    if col in df.columns:
        n_unique = df[col].nunique()
        print(f"{col:18} → {n_unique:4} unique values")

print("\nRecommendation:")
print("• One-hot     : Married/Single, House_Ownership, Car_Ownership, age_group")
print("• Target / Frequency / Mean encoding : Profession, CITY, STATE (high cardinality)")

# ─── Final look ─────────────────────────────────────────────────────
print("\n" + "═" * 70)
print("               PREPROCESSING SUMMARY")
print("═" * 70)
print("• No missing values" if missing.sum() == 0 else "• Missing values present")
print("• Numerical features normalized (0–1)")
print("• Categorical features:", len(cat_cols))
print("• Target imbalance → consider SMOTE / class_weight / undersampling")

