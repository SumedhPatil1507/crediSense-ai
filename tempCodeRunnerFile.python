# ────────────────────────────────────────────────────────────────
#       IMPORTANT LINE PLOTS 
# ────────────────────────────────────────────────────────────────

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# ─── Styling ───────────────────────────────────────────────────────
sns.set_style("whitegrid")
plt.rcParams['figure.dpi'] = 110
plt.rcParams['figure.figsize'] = (10.5, 5.5)

# ─── Assuming df is already loaded and Risk_Flag is integer ────────
if 'Risk_Flag' in df.columns and df['Risk_Flag'].dtype in ['float64', 'float32']:
    df['Risk_Flag'] = df['Risk_Flag'].astype(int)

# ─── 1. Cumulative default concentration (robust) ───────────────────
def plot_cumulative_default_rate(df, col, ascending=True, title=None):
    sorted_df = df.sort_values(col, ascending=ascending).reset_index(drop=True)
    total_defaults = sorted_df['Risk_Flag'].sum()
    
    if total_defaults == 0:
        print(f"→ {col}: No defaults in dataset – skipping cumulative plot.")
        return
    
    sorted_df['cum_default_pct'] = sorted_df['Risk_Flag'].cumsum() / total_defaults * 100

    plt.figure(figsize=(10.5, 5.8))
    plt.plot(np.linspace(0, 100, len(sorted_df)), sorted_df['cum_default_pct'],
             color='#8e44ad', linewidth=2.8)

    plt.axhline(50, color='gray', linestyle='--', alpha=0.7, linewidth=1)
    plt.text(2, 52, '50% of defaults', color='gray', fontsize=10)

    plt.title(title or f"Cumulative % of Defaults when sorted by {col}", 
              fontsize=13, fontweight='bold')
    plt.xlabel(f"Population % (sorted by {col} {'ascending' if ascending else 'descending'})")
    plt.ylabel("Cumulative % of All Defaults")
    plt.grid(True, alpha=0.3)
    plt.xlim(0, 100)
    plt.ylim(0, 105)
    plt.tight_layout()
    plt.show()


print("\n=== Cumulative Default Concentration Plots ===\n")

for col in ["Income", "income_per_experience", "stability_score"]:
    if col in df.columns:
        print(f"→ {col} (sorted descending – highest first)")
        plot_cumulative_default_rate(df, col, ascending=False)


# ─── 2. Bonus: Default rate line by ordered age_group ───────────────
if 'age_group' in df.columns:
    order = ['Young', 'Middle', 'Senior', 'Old']
    rate = df.groupby('age_group', observed=True)['Risk_Flag'].mean() * 100
    rate = rate.reindex(order)  # ensure correct order

    plt.figure(figsize=(9, 5.5))
    plt.plot(order, rate.values, marker='o', color='#27ae60', linewidth=2.8, markersize=10)
    for i, val in enumerate(rate.values):
        plt.text(i, val + 0.8, f"{val:.1f}%", ha='center', fontsize=10, fontweight='bold')
    
    plt.title("Default Rate Trend by Age Group", fontsize=13, fontweight='bold')
    plt.ylabel("Default Rate (%)")
    plt.xlabel("Age Group")
    plt.grid(True, alpha=0.4)
    plt.tight_layout()
    plt.show()

print("\nAll line plots generated successfully!")

