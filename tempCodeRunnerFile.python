# %%
# ────────────────────────────────────────────────────────────────
#       IMPORTANT HISTOGRAMS for Loan Risk Prediction
# ────────────────────────────────────────────────────────────────

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# ─── Styling ───────────────────────────────────────────────────────
plt.style.use('seaborn-v0_8-pastel')
sns.set_palette("muted")
plt.rcParams['figure.dpi'] = 100
plt.rcParams['figure.figsize'] = (10, 5.5)

df = pd.read_csv("/kaggle/input/loan-default-risk-dataset-with-feature-engineering/loan_cleaned.csv")

# ─── 1. Function to plot histogram with risk flag comparison ──
def plot_hist_kde_compare(df, column, title=None, bins=35, log_scale=False):
    """
    Creates:
    - Overall histogram 
    - Side-by-side comparison for Risk_Flag = 0 vs 1
    """
    fig, axes = plt.subplots(1, 2, figsize=(14, 5.5), gridspec_kw={'width_ratios': [1.1, 1]})
    
    # Left: overall distribution
    ax1 = axes[0]
    sns.histplot(data=df, x=column, kde=True, bins=bins, ax=ax1, color='teal', stat='density')
    ax1.set_title(f"Distribution of {column}", fontsize=13, fontweight='bold')
    ax1.set_xlabel(column)
    ax1.set_ylabel("Density")
    if log_scale:
        ax1.set_xscale('log')
        ax1.set_xlabel(f"{column} (log scale)")
    
    # Right: comparison by risk flag
    ax2 = axes[1]
    sns.histplot(data=df, x=column, hue='Risk_Flag', kde=True, bins=bins,
                 ax=ax2, palette={0: '#4c8bf5', 1: '#e74c3c'},
                 stat='density', common_norm=False, alpha=0.6)
    ax2.set_title(f"{column} by Risk Flag (0 = Safe, 1 = Risk)", fontsize=13, fontweight='bold')
    ax2.set_xlabel(column)
    ax2.set_ylabel("Density")
    if log_scale:
        ax2.set_xscale('log')
        ax2.set_xlabel(f"{column} (log scale)")
    
    plt.suptitle(title or f"Important Distribution: {column}", fontsize=15, fontweight='bold', y=1.02)
    plt.tight_layout()
    plt.show()

# ─── 2. Most important numeric features to visualize ────────────────
important_numeric_features = [
    "Income",
    "Age",
    "Experience",
    "CURRENT_JOB_YRS",
    "CURRENT_HOUSE_YRS",
    "income_per_experience",
    "stability_score"
]

print("Generating important histograms ...\n")

for feature in important_numeric_features:
    if feature in df.columns:
        skewed = df[feature].skew() > 1.5
        title_suffix = " (log scale recommended)" if skewed else ""
        
        print(f"→ Plotting: {feature}  (skew = {df[feature].skew():.2f})")
        plot_hist_kde_compare(
            df,
            column=feature,
            title=f"Distribution: {feature}{title_suffix}",
            bins=40,
            log_scale=skewed and feature in ["income_per_experience"]  # usually only this one is very skewed
        )

# ─── 3. Special: Age group bar plot (categorical but very informative) ──
print("\n→ Plotting: age_group distribution by Risk Flag")

plt.figure(figsize=(9, 5.5))
sns.countplot(data=df, x='age_group', hue='Risk_Flag',
              palette={0: '#4c8bf5', 1: '#e74c3c'}, order=['Young','Middle','Senior','Old'])
plt.title("Risk Flag Distribution by Age Group", fontsize=14, fontweight='bold')
plt.xlabel("Age Group")
plt.ylabel("Count of Applicants")
plt.legend(title="Risk Flag", labels=['Safe (0)', 'Risk (1)'])
plt.tight_layout()
plt.show()

# ─── 4. Quick correlation heatmap of numeric features ───────────────
print("\n→ Plotting: Correlation heatmap of numeric features")

numeric_df = df.select_dtypes(include=['float64','int64'])
corr = numeric_df.corr()

plt.figure(figsize=(10, 8))
sns.heatmap(corr, annot=True, fmt=".2f", cmap='coolwarm', vmin=-1, vmax=1,
            linewidths=0.5, annot_kws={"size": 9})
plt.title("Correlation Matrix – Numeric Features", fontsize=14, fontweight='bold')
plt.tight_layout()
plt.show()

print("\n" + "═"*70)
print("  Summary – What to look for in these plots:")
print("═"*70)
print("• Income & income_per_experience → usually right-skewed → log transform helpful")
print("• Age & Experience → multimodal or uniform patterns common")
print("• CURRENT_JOB_YRS & CURRENT_HOUSE_YRS → many people at 0–2 or 10+ years")
print("• stability_score → check if it behaves differently for risky applicants")
print("• Risk flag separation → look for features where red & blue KDEs are clearly different")
print("• age_group → often Senior/Old applicants have different risk patterns")

