# ────────────────────────────────────────────────────────────────
#       IMPORTANT BARPLOTS & COUNTPLOTS - Loan Risk Prediction
# ────────────────────────────────────────────────────────────────

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# ─── Styling ───────────────────────────────────────────────────────
plt.style.use('seaborn-v0_8-whitegrid')
sns.set_palette("deep")
plt.rcParams['figure.dpi'] = 100
plt.rcParams['figure.figsize'] = (10, 5.5)

df = pd.read_csv("/kaggle/input/loan-default-risk-dataset-with-feature-engineering/loan_cleaned.csv")

# ─── 1. Function: Countplot with Risk_Flag hue ──────────────────────
def plot_countplot(df, x_col, hue='Risk_Flag', title=None, order=None, figsize=(10,5.5)):
    """
    Creates clean countplot with Risk_Flag comparison
    """
    plt.figure(figsize=figsize)
    ax = sns.countplot(
        data=df,
        x=x_col,
        hue=hue,
        order=order,
        palette={0: '#5dade2', 1: '#e74c3c'},
        alpha=0.9
    )
    
    # Add value labels on bars
    for p in ax.patches:
        ax.annotate(f'{int(p.get_height())}',
                    (p.get_x() + p.get_width()/2., p.get_height()),
                    ha='center', va='bottom', fontsize=9)
    
    plt.title(title or f"Count of Applicants by {x_col} & Risk Flag", fontsize=14, fontweight='bold')
    plt.xlabel(x_col, fontsize=11)
    plt.ylabel("Number of Applicants", fontsize=11)
    plt.legend(title="Risk Flag", labels=['Safe (0)', 'Risk (1)'], loc='upper right')
    plt.xticks(rotation=45, ha='right')
    plt.tight_layout()
    plt.show()

# ─── 2. Function: Barplot – Mean of numeric feature by category ─────
def plot_mean_by_category(df, cat_col, num_col, title=None, figsize=(10,5.5)):
    """
    Shows average value of a numeric column grouped by a categorical column
    + Risk_Flag comparison
    """
    plt.figure(figsize=figsize)
    
    # Mean value by category
    means = df.groupby(cat_col)[num_col].mean().sort_values(ascending=False)
    
    ax = sns.barplot(
        x=means.index,
        y=means.values,
        palette='viridis',
        order=means.index
    )
    
    # Add value labels
    for p in ax.patches:
        ax.annotate(f'{p.get_height():.2f}',
                    (p.get_x() + p.get_width()/2., p.get_height()),
                    ha='center', va='bottom', fontsize=9)
    
    plt.title(title or f"Average {num_col} by {cat_col}", fontsize=14, fontweight='bold')
    plt.xlabel(cat_col, fontsize=11)
    plt.ylabel(f"Mean {num_col}", fontsize=11)
    plt.xticks(rotation=45, ha='right')
    plt.tight_layout()
    plt.show()
    
    # Bonus: split by Risk_Flag
    plt.figure(figsize=figsize)
    sns.barplot(
        data=df,
        x=cat_col,
        y=num_col,
        hue='Risk_Flag',
        estimator='mean',
        errorbar=None,
        palette={0: '#5dade2', 1: '#e74c3c'},
        order=means.index
    )
    plt.title(f"Mean {num_col} by {cat_col} & Risk Flag", fontsize=14, fontweight='bold')
    plt.xlabel(cat_col)
    plt.ylabel(f"Mean {num_col}")
    plt.xticks(rotation=45, ha='right')
    plt.legend(title="Risk Flag", labels=['Safe (0)', 'Risk (1)'])
    plt.tight_layout()
    plt.show()

# ─── 3. Most important categorical columns to visualize ─────────────
important_cats = [
    "Married/Single",
    "House_Ownership",
    "Car_Ownership",
    "age_group"
]

high_cardinality_cats = [
    "Profession",  # ~50 categories → top 10 shown
    "STATE"        # many states → top 12 shown
]

print("Generating important countplots & mean barplots...\n")

# ─── A. Low-cardinality categoricals ───────────────────────────────
for col in important_cats:
    if col in df.columns:
        print(f"\n→ Plotting: {col}")
        plot_countplot(
            df,
            x_col=col,
            title=f"Applicants by {col} & Risk Flag"
        )

# ─── B. High-cardinality → show top N ──────────────────────────────
for col in high_cardinality_cats:
    if col in df.columns:
        print(f"\n→ Plotting top categories of: {col}")
        
        # Top 12 most frequent
        top_cats = df[col].value_counts().head(12).index
        
        # Countplot - top categories
        plot_countplot(
            df[df[col].isin(top_cats)],
            x_col=col,
            title=f"Top 12 {col} by Count & Risk Flag",
            order=top_cats,
            figsize=(12, 6)
        )

# ─── C. Important numeric vs categorical means ─────────────────────
important_combinations = [
    ("age_group",        "Income"),
    ("House_Ownership",  "Income"),
    ("Car_Ownership",    "Income"),
    ("age_group",        "income_per_experience"),
    ("House_Ownership",  "CURRENT_HOUSE_YRS"),
    ("Married/Single",   "CURRENT_JOB_YRS"),
]

print("\nGenerating mean value comparisons...\n")

for cat, num in important_combinations:
    if cat in df.columns and num in df.columns:
        print(f"→ Mean {num} by {cat}")
        plot_mean_by_category(df, cat_col=cat, num_col=num)

# ─── Summary message ────────────────────────────────────────────────
print("\n" + "═"*75)
print("  KEY INSIGHTS YOU SHOULD LOOK FOR IN THESE PLOTS")
print("═"*75)
print("• Married/Single      → single applicants often have slightly higher risk proportion")
print("• House_Ownership     → 'rented' is dominant; 'owned' usually safer")
print("• Car_Ownership       → 'yes' often correlates with higher income & lower risk")
print("• age_group           → 'Senior' & 'Old' sometimes show different risk behavior")
print("• Profession / STATE  → some professions/states have very different risk rates")
print("• Income by ownership → owners tend to have higher average income")
print("• income_per_experience → very high values often safer (experienced + high income)")
print("\nThese plots help decide:")
print("• Which categories to target-encode or group")
print("• Which features show good separation for Risk_Flag")
print("• Where feature interactions might be useful")

