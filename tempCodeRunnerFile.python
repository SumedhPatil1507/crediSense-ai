# ================================================================
#          PIE CHARTS – Loan Risk Dataset EDA
# ================================================================

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# ─── Styling ───────────────────────────────────────────────────────
plt.style.use('seaborn-v0_8-pastel')
plt.rcParams['figure.dpi'] = 100
plt.rcParams['figure.figsize'] = (8, 8)

df = pd.read_csv("/kaggle/input/loan-default-risk-dataset-with-feature-engineering/loan_cleaned.csv")

# Make sure Risk_Flag is integer (cleaner)
if 'Risk_Flag' in df.columns and df['Risk_Flag'].dtype != 'int':
    df['Risk_Flag'] = df['Risk_Flag'].astype(int)


def plot_pie_chart(df, column, title=None, cmap='Pastel1',
                   min_pct_to_show=1.5, explode_top=0.08,
                   figsize=(8, 8), show_counts=True):
    """
    Safe pie chart:
    - groups small categories into 'Others'
    - custom labels with % and count
    - no unpacking error (handles autopct=None safely)
    """
    counts = df[column].value_counts()
    total = len(df)

    # Group very small categories
    small_mask = counts / total * 100 < min_pct_to_show
    if small_mask.any():
        others_count = counts[small_mask].sum()
        counts = counts[~small_mask].copy()
        counts['Others'] = others_count

    # Prepare labels
    labels = []
    for cat, cnt in counts.items():
        pct = cnt / total * 100
        label = f"{cat}\n{pct:.1f}%"
        if show_counts:
            label += f"\n({cnt:,})"
        labels.append(label)

    # Colors
    colors = plt.get_cmap(cmap)(range(len(counts)))

    # Explode largest slice
    explode = [0] * len(counts)
    if len(explode) > 0:
        explode[0] = explode_top

    fig, ax = plt.subplots(figsize=figsize)

    # Draw pie – do NOT unpack if we don't need autotexts
    wedges, texts = ax.pie(
        counts,
        labels=labels,
        autopct=None,               # we create our own percentage labels
        startangle=90,
        explode=explode,
        shadow=True,
        colors=colors,
        textprops={'fontsize': 10}
    )

    # Add percentage inside slices (only for bigger pieces)
    for i, (wedge, pct) in enumerate(zip(wedges, counts / total * 100)):
        if pct >= 5:  # only show on slices ≥ 5%
            ang = (wedge.theta2 - wedge.theta1) / 2. + wedge.theta1
            x = np.cos(np.deg2rad(ang)) * 0.65
            y = np.sin(np.deg2rad(ang)) * 0.65
            ax.text(x, y, f"{pct:.1f}%", ha='center', va='center',
                    fontsize=10, fontweight='bold', color='black')

    ax.set_title(title or f"Distribution of {column}", 
                 fontsize=14, fontweight='bold', pad=20)
    
    plt.axis('equal')
    plt.tight_layout()
    plt.show()


# ─── Main execution – most important pies ───────────────────────────

important_columns = [
    "Risk_Flag",              # target – always show first
    "Married/Single",
    "House_Ownership",
    "Car_Ownership",
    "age_group",
]

print("Generating important pie charts...\n")

for col in important_columns:
    if col in df.columns:
        print(f"→ {col}")
        plot_pie_chart(
            df,
            column=col,
            title=f"Distribution of {col}",
            cmap='RdYlBu' if col == "Risk_Flag" else 'Pastel1',
            min_pct_to_show=1.5,
            explode_top=0.10,
            show_counts=True
        )


# ─── Optional: Risk proportion inside key groups (stacked bar) ──────

print("\nRisk Flag proportion within important categories:\n")

group_cols = ["House_Ownership", "Car_Ownership", "age_group"]

for grp in group_cols:
    if grp in df.columns:
        print(f"→ Risk proportion by {grp}")

        crosstab = pd.crosstab(df[grp], df['Risk_Flag'], normalize='index') * 100

        fig, ax = plt.subplots(figsize=(9, 5.5))
        crosstab.plot(kind='bar', stacked=True, ax=ax,
                      color=['#6baed6', '#e74c3c'], width=0.72)

        ax.set_title(f"Risk Flag % by {grp}", fontsize=13, fontweight='bold')
        ax.set_ylabel("Percentage")
        ax.set_xlabel(grp)
        ax.legend(title="Risk Flag", labels=['Safe (0)', 'Risk (1)'],
                  loc='upper right', bbox_to_anchor=(1.18, 1))
        ax.set_ylim(0, 100)

        # Add percentage labels on bars
        for c in ax.containers:
            labels = [f'{v:.1f}%' if v > 4 else '' for v in [b.get_height() for b in c]]
            ax.bar_label(c, labels=labels, label_type='center',
                         color='white', fontsize=9, fontweight='bold')

        plt.xticks(rotation=45, ha='right')
        plt.tight_layout()
        plt.show()

