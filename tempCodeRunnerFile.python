import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# Load the cleaned dataset
df = pd.read_csv('/kaggle/input/loan-default-risk-dataset-with-feature-engineering/loan_cleaned.csv')

# Set aesthetic style
sns.set(style="whitegrid")

# Create a figure with subplots (3 rows, 2 columns)
fig, axes = plt.subplots(nrows=3, ncols=2, figsize=(16, 18))

# 1. Income vs Risk_Flag
sns.boxplot(x='Risk_Flag', y='Income', data=df, ax=axes[0, 0], palette='Set2')
axes[0, 0].set_title('Income Distribution by Risk Flag')
axes[0, 0].set_xlabel('Risk Flag (0: Non-Defaulter, 1: Defaulter)')
axes[0, 1].set_ylabel('Normalized Income')

# 2. Age vs Risk_Flag
sns.boxplot(x='Risk_Flag', y='Age', data=df, ax=axes[0, 1], palette='Set2')
axes[0, 1].set_title('Age Distribution by Risk Flag')
axes[0, 1].set_xlabel('Risk Flag')
axes[0, 1].set_ylabel('Normalized Age')

# 3. Experience vs Risk_Flag
sns.boxplot(x='Risk_Flag', y='Experience', data=df, ax=axes[1, 0], palette='Set2')
axes[1, 0].set_title('Years of Experience by Risk Flag')
axes[1, 0].set_xlabel('Risk Flag')
axes[1, 0].set_ylabel('Normalized Experience')

# 4. CURRENT_JOB_YRS vs Risk_Flag
sns.boxplot(x='Risk_Flag', y='CURRENT_JOB_YRS', data=df, ax=axes[1, 1], palette='Set2')
